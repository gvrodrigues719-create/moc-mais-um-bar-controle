# --- Supabase (projeto dedicado do +1 Bar) ---
# URL pública do projeto (não é segredo — pode ficar no .env.example)
NEXT_PUBLIC_SUPABASE_URL=https://ehuodergymmzikxvzmbw.supabase.co

# Chave publicável (anon) — usar somente no client-side
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chave secreta (service role) — usar SOMENTE server-side, NUNCA no client
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
NEXT_PUBLIC_APP_NAME="+1 Bar Controle"
NEXT_PUBLIC_STORE_NAME="+1 Bar"
